info:
	cat README.txt

funcion1:
	@echo "==================== f(x)=100 - (x - 10)^4 + 50(x + 10)^2;[3,17] ====================="
	gcc -fopenmp -o src/Main1 src/Main1.c
	./src/Main1 $(N)
	rm -f src/Main1
	@echo "======================================================================================"

funcion2:
	@echo "============================= f(x)=(x - 1)^2 + 25;[5,20] ============================="
	gcc -fopenmp -o src/Main2 src/Main2.c
	./src/Main2 $(N)
	rm -f src/Main2
	@echo "======================================================================================"

funcion3:
	@echo "============================= f(x)=(x - 4)^3 + 10;[2,16] ============================="
	gcc -fopenmp -o src/Main3 src/Main3.c
	./src/Main3 $(N)
	rm -f src/Main3
	@echo "======================================================================================"

all:
	@echo "==================== f(x)=100 - (x - 10)^4 + 50(x + 10)^2;[3,17] ====================="
	gcc -fopenmp -o src/Main1 src/Main1.c
	./src/Main1 $(N)
	rm -f src/Main1
	@echo "======================================================================================"
	@echo "============================= f(x)=(x - 1)^2 + 25;[5,20] ============================="
	gcc -fopenmp -o src/Main2 src/Main2.c
	./src/Main2 $(N)
	rm -f src/Main2
	@echo "======================================================================================"
	@echo "============================= f(x)=(x - 4)^3 + 10;[2,16] ============================="
	gcc -fopenmp -o src/Main3 src/Main3.c
	./src/Main3 $(N)
	rm -f src/Main3
	@echo "======================================================================================"


